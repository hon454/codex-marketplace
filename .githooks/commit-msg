#!/bin/sh

set -eu

message_file="$1"
first_line="$(sed -n '1p' "$message_file" | tr -d '\r')"

if [ -z "$first_line" ]; then
  echo "Aborting commit: commit message must not be empty." >&2
  exit 1
fi

case "$first_line" in
  Merge\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

pattern='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([[:alnum:]._-]+\))?(!)?: .+'

if printf '%s\n' "$first_line" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<'EOF'
Aborting commit: the subject line must follow Conventional Commits.

Expected format:
  type(scope): description

Examples:
  feat: add marketplace validation docs
  fix(plugin): align asset paths in plugin metadata
  docs!: rewrite setup guide for trusted Codex projects

Allowed types:
  build, chore, ci, docs, feat, fix, perf, refactor, revert, style, test
EOF

exit 1
